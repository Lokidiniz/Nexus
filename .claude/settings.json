{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python .nexus/hooks/reference-guard.py \"$NEXUS_OUTPUT_FILE\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python .nexus/hooks/constitution-enforcer.py \"$NEXUS_COMMAND\""
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(python .nexus/hooks/*)",
      "WebFetch(https://api.consensus.app/*)",
      "WebFetch(https://pubmed.ncbi.nlm.nih.gov/*)",
      "WebSearch(*)"
    ]
  }
}
